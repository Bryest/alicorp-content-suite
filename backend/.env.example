# ──────────────────────────────────────────────────────────────
# Content Suite — backend environment variables
#
# IMPORTANT: This system runs in MOCK MODE when keys are absent.
# Every service detects missing credentials at startup and falls
# back to a deterministic in-memory implementation so you can
# run the full creator → approver-a → approver-b flow with zero
# external accounts. Fill in keys to switch to real providers.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Without these, an in-memory Postgres-shaped store is used.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Groq (text generation, Llama 3.3) ─────────────────────────
# Without this, mock JSON brand-aware responses are returned.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google AI Studio (embeddings + Gemini vision) ─────────────
# Without this, deterministic hash-based embeddings + heuristic
# image audit are used.
GOOGLE_API_KEY=
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Langfuse (observability) ──────────────────────────────────
# Without these, traces are written to stdout instead.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Mock-mode JWT secret used when SUPABASE_JWT_SECRET is empty.
# In mock mode the API issues its own short-lived JWTs to the
# 3 demo users so the role-based flow is fully exercisable.
MOCK_JWT_SECRET=alicorp-content-suite-dev-secret-change-me

# RAG tuning knobs
RAG_TOP_K=3
RAG_MIN_SIMILARITY=0.5
LLM_TEMPERATURE=0.2
