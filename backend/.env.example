# ──────────────────────────────────────────────────────────────
# Content Suite — backend environment variables
#
# All external services are required. The API fails fast at
# startup if any of the credentials below are missing.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Groq (text generation, Llama 3.3) ─────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google AI Studio (embeddings + Gemini vision) ─────────────
GOOGLE_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ── Langfuse (observability) ──────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# RAG tuning knobs
RAG_TOP_K=3
RAG_MIN_SIMILARITY=0.5
LLM_TEMPERATURE=0.2
